<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#FAFAF8">
  <link rel="canonical" href="{{ canonical_url }}">
  <title>
    {%- if page_title == blank -%}{{ shop.name }}{%- else -%}{{ page_title }} — {{ shop.name }}{%- endif -%}
  </title>
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ 'clariva.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --cream:       #FAFAF8;
      --warm-white:  #F5F2EE;
      --sage:        #6B7C6A;
      --sage-light:  #8A9E89;
      --sage-dark:   #4E5C4D;
      --terra:       #C4714A;
      --charcoal:    #2C2C2C;
      --charcoal-mid:#4A4A48;
      --muted:       #8A8A80;
      --muted-light: #BBBBB0;
      --border:      #E5E2DC;
      --border-soft: #EDEBE6;
      --shadow:      rgba(44,44,44,.08);
      --serif:       'Playfair Display', Georgia, serif;
      --sans:        'Inter', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--sans);
      background: var(--cream);
      color: var(--charcoal);
      font-size: 14px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    button { font-family: var(--sans); cursor: pointer; }
    ul, ol { list-style: none; }
    .visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; }
  </style>
</head>

<body>

<!-- ═══ ANNOUNCEMENT BAR ═══ -->
<div class="ch-announce">
  <p>🇨🇦 Free shipping on orders over $50 CAD &nbsp;·&nbsp; Ships to Canada + USA &nbsp;·&nbsp; 30-Day Returns</p>
</div>

<!-- ═══ HEADER ═══ -->
<header class="ch-header" id="ch-header">
  <div class="ch-header-inner">

    <button class="ch-menu-toggle" id="ch-menu-toggle" aria-label="Open menu" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="2" y1="6" x2="20" y2="6"/><line x1="2" y1="11" x2="20" y2="11"/><line x1="2" y1="16" x2="20" y2="16"/>
      </svg>
    </button>

    <a href="/" class="ch-logo">
      <span class="ch-logo-text">Clariva<em>Home</em></span>
    </a>

    <nav class="ch-nav" id="ch-nav" role="navigation">
      <a href="/" class="ch-nav-link">Home</a>
      <a href="/collections/all" class="ch-nav-link">Shop All</a>
      <a href="/collections/kitchen-gadgets" class="ch-nav-link">Kitchen</a>
      <a href="/collections/home-organization" class="ch-nav-link">Organization</a>
      <a href="/collections/best-sellers" class="ch-nav-link">Best Sellers</a>
      <a href="/pages/about" class="ch-nav-link">About</a>
    </nav>

    <div class="ch-header-actions">
      <a href="/pages/contact" class="ch-header-icon" aria-label="Contact">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="4" width="16" height="12" rx="1"/><path d="M2 4l8 7 8-7"/>
        </svg>
      </a>
      <a href="/cart" class="ch-header-icon ch-cart-icon" aria-label="Cart">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M1 1h2l2.4 9.6a1 1 0 0 0 1 .8h9.2a1 1 0 0 0 1-.76L19 6H5"/>
          <circle cx="9" cy="17" r="1.2" fill="currentColor" stroke="none"/>
          <circle cx="15" cy="17" r="1.2" fill="currentColor" stroke="none"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="ch-cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <div class="ch-nav-drawer" id="ch-nav-drawer" aria-hidden="true">
    <a href="/" class="ch-nav-link">Home</a>
    <a href="/collections/all" class="ch-nav-link">Shop All</a>
    <a href="/collections/kitchen-gadgets" class="ch-nav-link">Kitchen Gadgets</a>
    <a href="/collections/home-organization" class="ch-nav-link">Home Organization</a>
    <a href="/collections/best-sellers" class="ch-nav-link">Best Sellers</a>
    <a href="/pages/about" class="ch-nav-link">About</a>
    <a href="/pages/contact" class="ch-nav-link">Contact</a>
  </div>
</header>

<main id="MainContent" role="main" tabindex="-1">
  {{ content_for_layout }}
</main>

<!-- ═══ FOOTER ═══ -->
<footer class="ch-footer">
  <div class="ch-footer-inner">

    <div class="ch-footer-brand">
      <a href="/" class="ch-logo">
        <span class="ch-logo-text">Clariva<em>Home</em></span>
      </a>
      <p class="ch-footer-tagline">Smart solutions for modern homes.<br>Thoughtfully curated, always affordable.</p>
      <div class="ch-footer-social">
        <a href="#" aria-label="Instagram" class="ch-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        </a>
        <a href="#" aria-label="TikTok" class="ch-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
        </a>
        <a href="#" aria-label="Pinterest" class="ch-social-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a10 10 0 0 0-4 19.2c0-1.1.2-2.8.4-3.3l1.4-5.9s-.4-.7-.4-1.7c0-1.6.9-2.8 2.3-2.8 1.1 0 1.6.8 1.6 1.8 0 1.1-.7 2.7-1 4.2-.3 1.3.6 2.3 1.8 2.3 2.1 0 3.5-2.7 3.5-5.9 0-2.4-1.6-4.2-4.5-4.2-3.3 0-5.3 2.4-5.3 5.1 0 .9.3 1.6.7 2"/></svg>
        </a>
      </div>
    </div>

    <div class="ch-footer-links">
      <div class="ch-footer-col">
        <h4 class="ch-footer-heading">Shop</h4>
        <a href="/collections/all">All Products</a>
        <a href="/collections/kitchen-gadgets">Kitchen Gadgets</a>
        <a href="/collections/home-organization">Home Organization</a>
        <a href="/collections/best-sellers">Best Sellers</a>
        <a href="/collections/new-arrivals">New Arrivals</a>
      </div>
      <div class="ch-footer-col">
        <h4 class="ch-footer-heading">Help</h4>
        <a href="/pages/shipping">Shipping Info</a>
        <a href="/pages/returns">Returns & Exchanges</a>
        <a href="/pages/faq">FAQ</a>
        <a href="/pages/contact">Contact Us</a>
        <a href="/pages/track-order">Track Order</a>
      </div>
      <div class="ch-footer-col">
        <h4 class="ch-footer-heading">Company</h4>
        <a href="/pages/about">About Clariva</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
        <a href="/policies/refund-policy">Refund Policy</a>
      </div>
    </div>

    <div class="ch-footer-newsletter">
      <h4 class="ch-footer-heading">Stay in the loop</h4>
      <p>Exclusive deals, home tips, and new arrivals — straight to your inbox.</p>
      {% form 'customer', id: 'footer-newsletter' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="ch-newsletter-row">
          <input type="email" name="contact[email]" placeholder="your@email.com" class="ch-newsletter-input" required>
          <button type="submit" class="ch-btn-sage">Subscribe</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="ch-newsletter-success">Thanks! Check your inbox for a welcome gift. 🎁</p>
        {%- endif -%}
      {% endform %}
    </div>

  </div>

  <div class="ch-footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} Clariva Home. All rights reserved. 🇨🇦 Proudly Canadian-Owned.</p>
    <div class="ch-payment-icons">
      <span>Visa</span><span>Mastercard</span><span>Amex</span><span>PayPal</span><span>Shop Pay</span><span>Interac</span>
    </div>
  </div>
</footer>

{{ 'clariva.js' | asset_url | script_tag }}

</body>
</html>
