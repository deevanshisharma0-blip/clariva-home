<section class="collection-page">
  <div class="collection-header">
    <h1 class="collection-title">{{ collection.title | default: 'The Collection' }}</h1>
    <p class="collection-desc">{{ collection.description }}</p>
  </div>

  <div class="collection-grid">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" class="product-card">
        <div class="product-card__image">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy">
          {%- endif -%}
          {%- if product.compare_at_price_max > product.price_min -%}
            <span class="product-card__badge">Sale</span>
          {%- endif -%}
        </div>
        <div class="product-card__info">
          <p class="product-card__vendor">{{ product.vendor }}</p>
          <h3 class="product-card__title">{{ product.title }}</h3>
          <div class="product-card__price">
            <span>{{ product.price_min | money }}</span>
            {%- if product.compare_at_price_max > product.price_min -%}
              <span class="compare">{{ product.compare_at_price_max | money }}</span>
            {%- endif -%}
          </div>
        </div>
      </a>
    {%- else -%}
      <p style="color:#666; font-family: var(--ff-sans);">No products found.</p>
    {%- endfor -%}
  </div>
</section>

<style>
.collection-page { max-width: 1200px; margin: 0 auto; padding: 80px 24px; }
.collection-header { text-align: center; margin-bottom: 72px; }
.collection-title { font-family: var(--ff-serif); font-size: clamp(32px,5vw,64px); font-weight: 300; color: #fff; letter-spacing: .06em; margin-bottom: 16px; }
.collection-desc { font-family: var(--ff-sans); font-size: 14px; color: #888; max-width: 480px; margin: 0 auto; line-height: 1.8; }
.collection-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 40px; }
.product-card { text-decoration: none; display: block; }
.product-card__image { position: relative; overflow: hidden; aspect-ratio: 1; background: #0d0d0d; margin-bottom: 20px; }
.product-card__image img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s ease; display: block; }
.product-card:hover .product-card__image img { transform: scale(1.04); }
.product-card__badge { position: absolute; top: 16px; left: 16px; background: var(--gold); color: var(--blk); font-family: var(--ff-sans); font-size: 10px; letter-spacing: .15em; padding: 4px 10px; text-transform: uppercase; }
.product-card__info { padding: 0 4px; }
.product-card__vendor { font-family: var(--ff-sans); font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--gold); margin: 0 0 8px; }
.product-card__title { font-family: var(--ff-serif); font-size: 20px; color: #fff; font-weight: 300; margin: 0 0 12px; line-height: 1.3; }
.product-card__price { font-family: var(--ff-serif); font-size: 18px; color: #ccc; display: flex; gap: 12px; align-items: baseline; }
.product-card__price .compare { font-size: 14px; color: #555; text-decoration: line-through; font-family: var(--ff-sans); }
</style>

{% schema %}
{
  "name": "LUMÈRA Collection",
  "settings": []
}
{% endschema %}
