<!-- LUMERA_V3_ACTIVE -->
<style>
/* HERO */
.lhero{min-height:calc(100vh - 68px);display:grid;grid-template-columns:1fr 1fr;align-items:center;max-width:1200px;margin:0 auto;padding:80px 32px;gap:64px}
.lhero-h1{font-family:var(--serif);font-size:clamp(40px,5.5vw,72px);font-weight:300;line-height:1.08;letter-spacing:.04em;margin-bottom:22px}
.lhero-h1 em{font-style:italic;color:var(--gold)}
.lhero-sub{font-size:15px;color:var(--muted);line-height:1.85;margin-bottom:32px;max-width:440px}
.lhero-ctas{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px}
.lhero-meta{display:flex;gap:24px;flex-wrap:wrap}
.lhero-meta-item{display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--muted);letter-spacing:.04em}
.lhero-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.lhero-visual{position:relative;display:flex;align-items:center;justify-content:center}
.lhero-glow{position:absolute;width:360px;height:360px;border-radius:50%;background:radial-gradient(circle,rgba(196,163,90,.1) 0%,rgba(196,163,90,.03) 50%,transparent 70%);pointer-events:none}
.lhero-img{width:100%;max-width:420px;height:480px;object-fit:cover;position:relative;z-index:1}
.lhero-placeholder{width:320px;height:400px;background:linear-gradient(145deg,var(--blk3),var(--blk4));border:1px solid var(--border2);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;position:relative;z-index:1}
.lhero-placeholder-ring{width:96px;height:96px;border:1px solid rgba(196,163,90,.25);border-radius:50%;display:flex;align-items:center;justify-content:center}
.lhero-placeholder-inner{width:56px;height:56px;border:1px solid rgba(196,163,90,.4);border-radius:50%}
.lhero-placeholder-name{font-family:var(--serif);font-size:24px;letter-spacing:.1em;color:rgba(196,163,90,.45)}
.lhero-placeholder-sub{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(196,163,90,.3)}
/* TRUST BAR */
.ltrust{background:var(--blk2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:20px 32px}
.ltrust-inner{max-width:1200px;margin:0 auto;display:flex;justify-content:center;gap:40px;flex-wrap:wrap}
.ltrust-item{display:flex;align-items:center;gap:9px;font-size:11.5px;letter-spacing:.07em;color:var(--muted)}
.ltrust-item svg{color:var(--gold);flex-shrink:0;width:15px;height:15px}
/* COLLECTION */
.lcollection{padding:96px 32px;background:var(--blk)}
.lcoll-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.lcard{background:var(--blk3);border:1px solid var(--border);transition:border-color .3s}
.lcard:hover{border-color:rgba(196,163,90,.3)}
.lcard-img{aspect-ratio:1/1;overflow:hidden;background:var(--blk4);display:flex;align-items:center;justify-content:center}
.lcard-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
.lcard:hover .lcard-img img{transform:scale(1.04)}
.lcard-img-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(150deg,var(--blk3),var(--blk4))}
.lcard-ring{width:80px;height:80px;border:1px solid rgba(196,163,90,.2);border-radius:50%;display:flex;align-items:center;justify-content:center}
.lcard-ring-inner{width:46px;height:46px;border:1px solid rgba(196,163,90,.35);border-radius:50%}
.lcard-body{padding:28px}
.lcard-tag{font-size:9px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(196,163,90,.28);padding:4px 10px;display:inline-block;margin-bottom:12px}
.lcard h3{font-family:var(--serif);font-size:22px;font-weight:300;letter-spacing:.06em;margin-bottom:4px}
.lcard-sub{font-size:12px;color:var(--muted);letter-spacing:.04em;margin-bottom:16px}
.lcard-features{margin-bottom:20px}
.lcard-features li{font-size:12.5px;color:var(--muted);padding:6px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.lcard-features li::before{content:'—';color:var(--gold);font-size:11px;flex-shrink:0}
.lcard-price{font-family:var(--serif);font-size:28px;font-weight:300;letter-spacing:.04em;color:var(--gold);margin-bottom:16px}
/* RITUAL */
.lritual{padding:96px 32px;background:var(--blk2);border-top:1px solid var(--border)}
.lritual-steps{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:48px;position:relative}
.lritual-steps::before{content:'';position:absolute;top:26px;left:calc(16.6% + 20px);right:calc(16.6% + 20px);height:1px;background:linear-gradient(90deg,transparent,var(--border),var(--border),transparent)}
.lstep{text-align:center;padding:0 12px}
.lstep-num{font-family:var(--serif);font-size:52px;font-weight:300;color:rgba(196,163,90,.18);line-height:1;margin-bottom:20px}
.lstep h3{font-family:var(--serif);font-size:21px;font-weight:300;letter-spacing:.06em;margin-bottom:10px}
.lstep p{font-size:13.5px;color:var(--muted);line-height:1.8}
/* SCIENCE */
.lscience{padding:96px 32px;background:var(--blk)}
.lscience-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.lwave{background:var(--blk3);border:1px solid var(--border);padding:36px 28px;transition:border-color .3s}
.lwave:hover{border-color:rgba(196,163,90,.2)}
.lwave-chip{display:inline-block;font-size:10.5px;font-weight:600;letter-spacing:.1em;padding:6px 14px;margin-bottom:20px;border-radius:2px}
.lwave h3{font-family:var(--serif);font-size:21px;font-weight:300;letter-spacing:.05em;margin-bottom:12px}
.lwave p{font-size:13px;color:var(--muted);line-height:1.8}
.lwave-note{font-size:11px;color:var(--muted2);margin-top:14px;font-style:italic}
/* COMPARE */
.lcompare{padding:96px 32px;background:var(--blk2);border-top:1px solid var(--border)}
.lcmp-wrap{max-width:820px;margin:0 auto}
.lcmp-table{width:100%;border-collapse:collapse}
.lcmp-table th{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;font-weight:500;padding:16px 24px;text-align:left;border-bottom:1px solid var(--border)}
.lcmp-table th:nth-child(2){color:var(--gold)}
.lcmp-table th:nth-child(3){color:var(--muted)}
.lcmp-table td{padding:15px 24px;font-size:13px;border-bottom:1px solid #0d0d10;vertical-align:middle}
.lcmp-table td:first-child{font-size:11.5px;letter-spacing:.04em;color:var(--muted)}
.lcmp-table td:nth-child(2){color:var(--text)}
.lcmp-table td:nth-child(3){color:var(--muted)}
.lcmp-table tr:last-child td{border-bottom:none}
.lcmp-cta{text-align:center;margin-top:40px}
.lcmp-note{font-size:11px;color:var(--muted2);text-align:center;margin-top:12px}
/* FAQ */
.lfaq{padding:96px 32px;background:var(--blk)}
.lfaq-list{max-width:720px;margin:0 auto}
.lfaq-item{border-bottom:1px solid var(--border)}
.lfaq-q{width:100%;background:none;border:none;color:var(--text);text-align:left;padding:22px 0;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-size:14px;letter-spacing:.02em;gap:16px;transition:color .2s}
.lfaq-q:hover{color:var(--gold)}
.lfaq-icon{width:18px;height:18px;flex-shrink:0;position:relative;color:var(--gold)}
.lfaq-icon::before,.lfaq-icon::after{content:'';position:absolute;background:currentColor}
.lfaq-icon::before{width:12px;height:1px;top:50%;left:50%;transform:translate(-50%,-50%)}
.lfaq-icon::after{width:1px;height:12px;top:50%;left:50%;transform:translate(-50%,-50%);transition:transform .25s}
.lfaq-item.open .lfaq-icon::after{transform:translate(-50%,-50%) rotate(90deg)}
.lfaq-a{max-height:0;overflow:hidden;transition:max-height .35s ease}
.lfaq-item.open .lfaq-a{max-height:320px}
.lfaq-a p{font-size:13.5px;color:var(--muted);line-height:1.85;padding-bottom:22px}
/* RESPONSIVE */
@media(max-width:900px){
  .lhero{grid-template-columns:1fr;padding:48px 24px;min-height:auto;gap:40px}
  .lhero-visual{order:-1}
  .lhero-img{max-width:280px;height:320px;margin:0 auto}
  .lhero-placeholder{width:260px;height:320px}
  .lcoll-grid{grid-template-columns:1fr;max-width:480px}
  .lritual-steps{grid-template-columns:1fr;gap:36px}
  .lritual-steps::before{display:none}
  .lscience-grid{grid-template-columns:1fr}
  .lcmp-table th:first-child,.lcmp-table td:first-child{display:none}
  .lcmp-table td,.lcmp-table th{padding:12px 16px}
}
@media(max-width:600px){
  .lhero{padding:32px 20px}
  .lhero-h1{font-size:clamp(34px,9vw,50px)}
  .ltrust-item:nth-child(n+3){display:none}
  .lcollection,.lritual,.lscience,.lcompare,.lfaq{padding:64px 20px}
  .l-section-header{margin-bottom:40px}
  .ltrust{padding:18px 20px}
  .ltrust-inner{gap:20px}
}
</style>

